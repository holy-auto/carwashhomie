# ──────────────────────────────────────────────────────────────
# Contact form backend (Resend)
# ──────────────────────────────────────────────────────────────
# The /reservation contact form POSTs to /api/contact which
# relays the inquiry to BUSINESS.email
# (japanesedetailergirl@gmail.com) via the Resend API.
#
# One-time setup (no recipient involvement needed):
#
#   1. Sign up at https://resend.com with any email you own
#   2. Domains → Add Domain → enter `carwashhomies.com`
#   3. Copy the 3 TXT records Resend shows and add them to the
#      DNS provider that manages carwashhomies.com (Vercel,
#      Cloudflare, Namecheap, etc.). Usually verifies in minutes.
#   4. API Keys → Create API Key → copy the `re_...` value
#   5. Paste it below locally AND add it in
#      Vercel → Project Settings → Environment Variables
#      (Production + Preview), then redeploy.
#
# The key must stay server-side — never prefix it with NEXT_PUBLIC.
RESEND_API_KEY=

# Optional override. Defaults to
#   "Car Wash Homies <no-reply@carwashhomies.com>"
# Only set this if you verified a different sender in Resend.
RESEND_FROM=

# ──────────────────────────────────────────────────────────────
# Content management (Supabase + /admin panel)
# ──────────────────────────────────────────────────────────────
# Powers the self-service editor at /admin where the shop can edit
# 施術メニュー (body_coatings / wash_services) / 施術事例 (gallery) /
# お知らせ (news) / お客様の声 (testimonials).
#
# Find these in the Supabase dashboard for the "carwashhomies-site"
# project → Project Settings → API.
#
#   - URL and ANON key are safe to expose (NEXT_PUBLIC_*).
#   - SERVICE_ROLE key is secret — never prefix with NEXT_PUBLIC.
#
# Without these the site still runs and shows built-in sample
# content; the /admin panel just can't save.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: storage bucket name for uploaded photos (default: media)
SUPABASE_MEDIA_BUCKET=media

# ──────────────────────────────────────────────────────────────
# Admin login (the password the shop owner types at /admin)
# ──────────────────────────────────────────────────────────────
# ADMIN_PASSWORD       — the login password. Pick something strong.
# ADMIN_SESSION_SECRET — a long random string used to sign the
#                        session cookie. Generate one with:
#                          openssl rand -hex 32
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
